{
	"name": "spire",
	"private": true,
	"packageManager": "bun@1.3.3",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"test": "turbo test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "prettier --write '**/*.{tsx,ts}' --plugin prettier-plugin-tailwindcss",
		"format:check": "prettier --check '**/*.{tsx,ts}' --plugin prettier-plugin-tailwindcss",
		"typecheck": "turbo typecheck",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mjs,json}": "biome check --write --no-errors-on-unmatched",
		"*.{tsx,ts}": "prettier --write --plugin prettier-plugin-tailwindcss"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"turbo": "^2.8.17"
	}
}
