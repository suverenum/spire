# Demo/test script environment variables
# Copy this file to .env and fill in real values
# NEVER commit .env — it is gitignored

# Private keys for demo scripts (0x + 64 hex chars)
DEPLOYER_KEY=0x_your_deployer_private_key_here
AGENT_KEY=0x_your_agent_private_key_here

# Contract addresses (0x + 40 hex chars)
GUARDIAN_ADDRESS=0x_your_guardian_contract_address
TOKEN_ADDRESS=0x_your_token_contract_address
VENDOR_ADDRESS=0x_your_vendor_address
